# Copy to .env and adjust if needed. Defaults work out of the box for local dev.

# Warehouse Postgres (the analytical database dbt builds into)
WAREHOUSE_POSTGRES_HOST=localhost
WAREHOUSE_POSTGRES_PORT=5433
WAREHOUSE_POSTGRES_DB=sa_warehouse
WAREHOUSE_POSTGRES_USER=warehouse
WAREHOUSE_POSTGRES_PASSWORD=warehouse

# Airflow metadata Postgres (internal to Airflow, separate from the warehouse
# so orchestration state never mixes with analytical data)
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# Airflow
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
